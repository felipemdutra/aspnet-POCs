@HostAddr = http://localhost:5291

### List users
GET {{HostAddr}}/users

###

### Create user (valid)
POST {{HostAddr}}/users
Content-Type: application/json

{
    "email": "newuser@example.com",
    "password": "encryptedpassword321",
    "phone": "+5511999998888",
    "addressLine": "123 Main St",
    "addressComplement": null,
    "city": "Sao Paulo",
    "state": "SP",
    "zipCode": "01310-100"
}

###

### Create user (empty email - should return 400)
POST {{HostAddr}}/users
Content-Type: application/json

{
    "email": "",
    "password": "encryptedpassword321",
    "phone": "+5511999998888",
    "addressLine": "123 Main St",
    "addressComplement": null,
    "city": "Sao Paulo",
    "state": "SP",
    "zipCode": "01310-100"
}

###

### Create user (invalid email format - should return 400)
POST {{HostAddr}}/users
Content-Type: application/json

{
    "email": "not-an-email",
    "password": "encryptedpassword321",
    "phone": "+5511999998888",
    "addressLine": "123 Main St",
    "addressComplement": null,
    "city": "Sao Paulo",
    "state": "SP",
    "zipCode": "01310-100"
}

