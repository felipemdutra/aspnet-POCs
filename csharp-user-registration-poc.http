### Create user (missing required address fields - should return 400)
POST {{HostAddr}}/users
Content-Type: application/json

{
    "email": "noaddress@example.com",
    "password": "encryptedpassword321",
    "phone": "+5511999998888"
}

###

### Create user (only optional fields are null - should return 201)
POST {{HostAddr}}/users
Content-Type: application/json

{
    "email": "minimaluser@example.com",
    "password": "encryptedpassword321",
    "phone": null,
    "addressLine": "789 Pine Rd",
    "addressComplement": null,
    "city": "Belo Horizonte",
    "state": "MG",
    "zipCode": "30110000"
}

###

### Get user by id
GET {{HostAddr}}/users/2

###

### Update user (valid)
PUT {{HostAddr}}/users/2
Content-Type: application/json

{
    "email": "updateduser@example.com",
    "password": "differentpassword123",
    "phone": "+5511988887777",
    "addressLine": "456 Oak Ave",
    "addressComplement": "Apt 12",
    "city": "Rio de Janeiro",
    "state": "RJ",
    "zipCode": "20040-020"
}

###

### Update user (invalid email - should return 400)
PUT {{HostAddr}}/users/2
Content-Type: application/json

{
    "email": "not-an-email",
    "password": "differentpassword123",
    "phone": "+5511988887777",
    "addressLine": "456 Oak Ave",
    "addressComplement": "Apt 12",
    "city": "Rio de Janeiro",
    "state": "RJ",
    "zipCode": "20040-020"
}

###

### Update user that does not exist (should return 404)
PUT {{HostAddr}}/users/999
Content-Type: application/json

{
    "email": "ghost@example.com",
    "password": "encryptedpassword321",
    "phone": "+5511999998888",
    "addressLine": "1 Ghost St",
    "addressComplement": null,
    "city": "Sao Paulo",
    "state": "SP",
    "zipCode": "01310-100"
}

###

### Get user that does not exist (should return 404)
GET {{HostAddr}}/users/999

###

### Delete user that does not exist (should return 404)
DELETE {{HostAddr}}/users/999

###

### Delete user
DELETE {{HostAddr}}/users/1

###